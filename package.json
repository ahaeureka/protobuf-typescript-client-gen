{
    "name": "protobuf-typescript-client-gen",
    "version": "1.0.1",
    "description": "Standalone protoc plugin for Stew TypeScript Axios client generation.",
    "bin": {
        "protoc-gen-ts_client": "./dist/plugin.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "rm -rf dist && tsc -p tsconfig.json && chmod +x dist/plugin.js && node ./scripts/copy-google-runtime.mjs",
        "clean": "rm -rf dist",
        "watch": "tsc -p tsconfig.json --watch"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.14.0",
    "dependencies": {
        "google-protobuf": "^4.0.0",
        "handlebars": "^4.7.8"
    },
    "devDependencies": {
        "@types/google-protobuf": "^3.15.12",
        "@types/node": "^24.3.0",
        "typescript": "^5.9.2"
    }
}